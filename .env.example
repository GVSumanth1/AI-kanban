# Next.js Environment Variables

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Database
DATABASE_PATH=./data/kanban.db

# n8n Integration
N8N_WEBHOOK_URL=http://localhost:5678/webhook/email-classification
N8N_API_KEY=your_n8n_api_key_here

# Email Service
GMAIL_REFRESH_TOKEN=your_gmail_token
OUTLOOK_REFRESH_TOKEN=your_outlook_token

# AI Service (OpenAI, Anthropic, etc.)
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4

# General
NODE_ENV=development
PORT=3000
